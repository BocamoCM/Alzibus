<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background"
    android:id="@+id/widget_container">

    <!-- Título del widget -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🚌 Alzitrans"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

    <!-- Llegada 1 -->
    <LinearLayout
        android:id="@+id/arrival_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">
        
        <TextView
            android:id="@+id/line_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="L2"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/line_badge_background"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp" />
        
        <TextView
            android:id="@+id/destination_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hospital"
            android:textSize="11sp"
            android:textColor="#E0E0E0"
            android:layout_marginStart="8dp"
            android:ellipsize="end"
            android:maxLines="1" />
        
        <TextView
            android:id="@+id/time_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5 min"
            android:textSize="13sp"
            android:textColor="#4CAF50"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Llegada 2 -->
    <LinearLayout
        android:id="@+id/arrival_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:visibility="gone">
        
        <TextView
            android:id="@+id/line_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="L1"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/line_badge_background"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp" />
        
        <TextView
            android:id="@+id/destination_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Centro"
            android:textSize="11sp"
            android:textColor="#E0E0E0"
            android:layout_marginStart="8dp"
            android:ellipsize="end"
            android:maxLines="1" />
        
        <TextView
            android:id="@+id/time_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12 min"
            android:textSize="13sp"
            android:textColor="#4CAF50"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Llegada 3 -->
    <LinearLayout
        android:id="@+id/arrival_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:visibility="gone">
        
        <TextView
            android:id="@+id/line_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="L3"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/line_badge_background"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp" />
        
        <TextView
            android:id="@+id/destination_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Estación"
            android:textSize="11sp"
            android:textColor="#E0E0E0"
            android:layout_marginStart="8dp"
            android:ellipsize="end"
            android:maxLines="1" />
        
        <TextView
            android:id="@+id/time_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="18 min"
            android:textSize="13sp"
            android:textColor="#4CAF50"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Estado vacío -->
    <TextView
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sin favoritos"
        android:textSize="12sp"
        android:textColor="#9E9E9E"
        android:layout_marginTop="8dp"
        android:visibility="gone" />

    <!-- Última actualización -->
    <TextView
        android:id="@+id/last_update"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔄 --:--"
        android:textSize="9sp"
        android:textColor="#757575"
        android:layout_marginTop="6dp" />

</LinearLayout>
