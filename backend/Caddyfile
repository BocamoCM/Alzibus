# www → raíz canonical (HTML únicamente, sin tráfico de API por aquí).
www.alzitrans.es {
    redir https://alzitrans.es{uri} permanent
}

# alzitrans.duckdns.org sigue sirviendo la API y endpoints especiales
# DIRECTAMENTE (proxy al backend) — sin redirect — porque las APKs
# antiguas hacen POST/PUT/PATCH/DELETE y los clientes HTTP (Dio en
# Android, BrowserClient en web) NO conservan el body al seguir un
# 301/302 con POST, lo cual rompía el login y todas las mutaciones.
# Solo redirigimos las RUTAS HTML (web/landing/app/) al dominio nuevo:
#   - El navegador sigue 301 sin problema en GET.
#   - Google Search Console valida el "Change of address" comprobando
#     la raíz (que sí redirige), no los endpoints de API.
# Cuando la mayoría haya actualizado a la versión 5.3+ (3-6 meses),
# retiraremos este bloque entero — solo quedará alzitrans.es.
alzitrans.duckdns.org {
    # API + endpoints especiales: pasamos directo al backend, mismo
    # comportamiento que antes de la migración.
    handle /api/* {
        reverse_proxy alzibus_backend:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }
    handle /qr* {
        reverse_proxy alzibus_backend:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }
    handle /delete-account {
        reverse_proxy alzibus_backend:3000
    }
    handle /privacy-policy {
        reverse_proxy alzibus_backend:3000
    }
    handle /app-ads.txt {
        reverse_proxy alzibus_backend:3000
    }

    # El resto (HTML, /app/, raíz) sí redirige al dominio canónico.
    # Esto mantiene el SEO y permite el Change of address de Google.
    handle {
        redir https://alzitrans.es{uri} permanent
    }
}

alzitrans.es {
    # Smart QR Tracker — redirige al backend para registrar y luego a /descargar
    handle /qr* {
        reverse_proxy alzibus_backend:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Redirigir peticiones de la API al backend
    handle /api/* {
        reverse_proxy alzibus_backend:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Rutas especiales del backend (sin prefijo /api/)
    handle /delete-account {
        reverse_proxy alzibus_backend:3000
    }
    handle /privacy-policy {
        reverse_proxy alzibus_backend:3000
    }
    handle /app-ads.txt {
        reverse_proxy alzibus_backend:3000
    }

    # Redirigir /app a /app/ (Evita errores de rutas relativas)
    redir /app /app/

    # Configuración para la App en subruta /app
    handle /app/* {
        reverse_proxy alzibus_website:80
    }

    # El resto de peticiones van a la web principal (Landing Page)
    handle {
        reverse_proxy alzibus_website:80
    }
}
