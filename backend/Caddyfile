# Redirect 301 de www.alzitrans.es a la raíz alzitrans.es (canonical).
# Las dos resuelven a la misma IP, pero el SEO funciona mejor si
# escogemos una URL canónica y forzamos a la otra a redirigir — así
# Google no diluye autoridad entre dos versiones.
www.alzitrans.es {
    redir https://alzitrans.es{uri} permanent
}

# Servimos el dominio nuevo (alzitrans.es) Y el viejo (duckdns) en el
# mismo bloque. Caddy pide cert Let's Encrypt automáticamente para
# alzitrans.es la primera vez que llega una petición. El dominio
# duckdns sigue funcionando para usuarios con APKs antiguas — lo
# dejaremos varios meses hasta que la mayoría haya actualizado, y
# después lo retiramos.
alzitrans.es, alzitrans.duckdns.org {
    # Smart QR Tracker — redirige al backend para registrar y luego a /descargar
    handle /qr* {
        reverse_proxy alzibus_backend:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Redirigir peticiones de la API al backend
    handle /api/* {
        reverse_proxy alzibus_backend:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Rutas especiales del backend (sin prefijo /api/)
    handle /delete-account {
        reverse_proxy alzibus_backend:3000
    }
    handle /privacy-policy {
        reverse_proxy alzibus_backend:3000
    }
    handle /app-ads.txt {
        reverse_proxy alzibus_backend:3000
    }

    # Redirigir /app a /app/ (Evita errores de rutas relativas)
    redir /app /app/

    # Configuración para la App en subruta /app
    handle /app/* {
        reverse_proxy alzibus_website:80
    }

    # El resto de peticiones van a la web principal (Landing Page)
    handle {
        reverse_proxy alzibus_website:80
    }
}
