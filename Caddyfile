# www → raíz canonical.
www.alzitrans.es {
    redir https://alzitrans.es{uri} permanent
}

# alzitrans.duckdns.org: API directa al backend (sin redirect, para no
# romper POST/PUT de las APKs antiguas) + redirect 301 al dominio
# nuevo para todas las URLs HTML (mantiene SEO y Change of address).
alzitrans.duckdns.org {
    handle /api/* {
        reverse_proxy alzibus_backend:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }
    handle /qr* {
        reverse_proxy alzibus_backend:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }
    handle /delete-account {
        reverse_proxy alzibus_backend:3000
    }
    handle /privacy-policy {
        reverse_proxy alzibus_backend:3000
    }
    handle /app-ads.txt {
        reverse_proxy alzibus_backend:3000
    }
    handle {
        redir https://alzitrans.es{uri} permanent
    }
}

alzitrans.es {
    # Smart QR Tracker — redirige al backend para registrar y luego a /descargar
    handle /qr* {
        reverse_proxy alzibus_backend:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Redirigir peticiones de la API al backend
    handle /api/* {
        reverse_proxy alzibus_backend:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Rutas especiales del backend (sin prefijo /api/)
    handle /delete-account {
        reverse_proxy alzibus_backend:3000
    }
    handle /privacy-policy {
        reverse_proxy alzibus_backend:3000
    }
    handle /app-ads.txt {
        reverse_proxy alzibus_backend:3000
    }
    # Viewer público de "Compartir mi viaje en vivo".
    # URL corta tipo alzitrans.es/v/abc123xyz → backend devuelve HTML viewer
    # que hace polling a /api/live-trips/public/<token>.
    handle /v/* {
        reverse_proxy alzibus_backend:3000
    }

    # Redirigir /app a /app/ (Evita errores de rutas relativas)
    redir /app /app/

    # Configuración para la App en subruta /app
    handle /app/* {
        reverse_proxy alzibus_website:80
    }

    # El resto de peticiones van a la web principal (Landing Page)
    handle {
        reverse_proxy alzibus_website:80
    }
}
